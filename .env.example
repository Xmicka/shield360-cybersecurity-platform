# Shield360 Cybersecurity Platform — Environment Variables

# ─── Supabase (recommended: override the bundled fallbacks via env) ───
# These take precedence over the obfuscated values embedded in src/config/supabase.ts
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Module microservice API URLs ───
VITE_BEHAVIOR_API=
VITE_DEVICE_API=
VITE_THREAT_API=
VITE_COMPLIANCE_API=

# ─── Endpoint Scanner backend (Render) ───
# Replace 127.0.0.1:8000 with the production Render URL
VITE_API_BASE_URL=
