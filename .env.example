# Shield360 Cybersecurity Platform — Environment Variables
#
# Copy this file to .env.local for local dev. In Vercel, set the same keys
# under Project → Settings → Environment Variables.

# ─── Supabase (required) ──────────────────────────────────────────────────
# These take precedence over the obfuscated values embedded in
# src/config/supabase.ts. In production, the obfuscated fallbacks should be
# removed; require these to be set.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Module microservice API URLs ────────────────────────────────────────
VITE_BEHAVIOR_API=
VITE_DEVICE_API=
VITE_THREAT_API=
VITE_COMPLIANCE_API=

# ─── Endpoint Scanner backend (Render) ───────────────────────────────────
# Replace 127.0.0.1:8000 with the production Render URL
VITE_API_BASE_URL=

# ─── Contact form (Supabase Edge Function URL) ───────────────────────────
# After deploying supabase/functions/contact-form, paste the URL here:
#   https://<project-ref>.supabase.co/functions/v1/contact-form
# When unset, the contact form falls back to opening the user's mail client.
VITE_CONTACT_FORM_URL=

# ─── Telemetry (optional, but strongly recommended in prod) ──────────────
# Sentry: https://sentry.io  →  Settings → Projects → <project> → Client Keys
VITE_SENTRY_DSN=
# PostHog: https://posthog.com  →  Project settings → Project API Key
VITE_POSTHOG_KEY=
# us.i.posthog.com (default) or eu.i.posthog.com
VITE_POSTHOG_HOST=

# ─── App version (auto-injected by CI; shows in Sentry release tag) ──────
VITE_APP_VERSION=
